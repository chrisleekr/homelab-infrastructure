# Bitwarden Secrets Manager — the only values this file holds.
# Every other secret and config value (flattened, no ${...} interpolation) lives in the
# Bitwarden Secrets Manager project. When you launch the container, .bashrc runs `bws run`
# and injects them all as environment variables.
#
# Setup + full per-variable reference: docs/bitwarden-secrets-setup.md
# Get your project id with: bws project list
#
# Leave both empty in the committed template; fill them only in your gitignored .env.
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=
